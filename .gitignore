# =====================================================================
# Dependencies & build artifacts
# =====================================================================
node_modules/
dist/
build/
coverage/
.nyc_output/
*.tsbuildinfo

# =====================================================================
# Cloudflare Wrangler
# =====================================================================
.wrangler/
.wrangler-state/
wrangler.toml.bak

# =====================================================================
# Secrets & environment
# Whitelist file *.example agar tetap di-commit sebagai template.
# =====================================================================
.dev.vars
.dev.vars.*
!.dev.vars.example

.env
.env.*
!.env.example

# Sertifikat & kunci yang tidak boleh masuk repo, apa pun namanya.
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_ed25519

# =====================================================================
# Logs & temp
# =====================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp
tmp/

# =====================================================================
# Editors / IDEs
# =====================================================================
# VS Code: ignore launch.json yang biasanya berisi path personal,
# biarkan settings.json & extensions.json bisa di-share.
.vscode/launch.json
.vscode/*.local.json
*.code-workspace

# JetBrains
.idea/

# Vim / classic Unix editors
*.swp
*.swo
*~

# History (extension VS Code Local History dll)
.history/

# =====================================================================
# OS files
# =====================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
